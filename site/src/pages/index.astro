---
import Layout from "../layouts/Layout.astro";
import numbers from "../../public/data/numbers.json";

const ne = numbers.landing.northeast_funding_per_death;
const west = numbers.landing.west_funding_per_death;
const ratio = numbers.landing.ne_to_west_ratio_display;

function formatCurrency(value: number): string {
  return "$" + Math.round(value).toLocaleString("en-US");
}
---

<Layout title="Home — Alzheimer's Funding Alignment">
  <style>
    .hero-section {
      max-width: 1280px;
      margin: 0 auto;
      padding: 80px 24px 48px 24px;
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 48px;
      align-items: start;
    }
    @media (max-width: 900px) {
      .hero-section {
        grid-template-columns: 1fr;
      }
    }
    .pill {
      display: inline-block;
      background-color: #EDE9FE;
      color: #6D28D9;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 6px 14px;
      border-radius: 999px;
      margin-bottom: 24px;
    }
    .hero-headline {
      font-size: clamp(32px, 4.5vw, 56px);
      font-weight: 700;
      line-height: 1.1;
      color: #0F1535;
      margin: 0 0 24px 0;
      letter-spacing: -0.02em;
    }
    .hero-headline .accent {
      color: #7C3AED;
    }
    .hero-subhead {
      font-size: 16px;
      line-height: 1.6;
      color: #4B5563;
      margin: 0 0 32px 0;
      max-width: 520px;
    }
    .cta-row {
      display: flex;
      align-items: center;
      gap: 24px;
    }
    .cta-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background-color: #1F1B2E;
      color: white;
      padding: 14px 22px;
      border-radius: 8px;
      text-decoration: none;
      font-size: 15px;
      font-weight: 500;
    }
    .cta-primary:hover {
      background-color: #0F1535;
    }
    .cta-secondary {
      color: #4B5563;
      font-size: 15px;
      font-weight: 500;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }
    .cta-secondary:hover {
      color: #0F1535;
    }
    .stat-card {
      background-color: #1A1A3E;
      background-image: linear-gradient(135deg, #1A1A3E 0%, #261B4A 100%);
      border-radius: 16px;
      padding: 36px 32px;
      color: white;
      position: relative;
      overflow: hidden;
    }
    .stat-card::before {
      content: "";
      position: absolute;
      top: -40px;
      right: -40px;
      width: 200px;
      height: 200px;
      border: 2px solid rgba(255, 255, 255, 0.04);
      border-radius: 50%;
    }
    .stat-card::after {
      content: "";
      position: absolute;
      top: -10px;
      right: 0;
      width: 140px;
      height: 140px;
      border: 2px solid rgba(255, 255, 255, 0.05);
      border-radius: 50%;
    }
    .stat-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.6);
      margin-bottom: 16px;
      position: relative;
      z-index: 1;
    }
    .stat-value-purple {
      font-size: 56px;
      font-weight: 700;
      color: #A78BFA;
      line-height: 1;
      letter-spacing: -0.02em;
      position: relative;
      z-index: 1;
    }
    .stat-value-pink {
      font-size: 56px;
      font-weight: 700;
      color: #F472B6;
      line-height: 1;
      letter-spacing: -0.02em;
      position: relative;
      z-index: 1;
    }
    .stat-caption {
      font-size: 14px;
      color: rgba(255, 255, 255, 0.85);
      margin-top: 10px;
      position: relative;
      z-index: 1;
    }
    .stat-divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 24px 0;
      color: rgba(255, 255, 255, 0.5);
      font-size: 14px;
      font-weight: 500;
      position: relative;
      z-index: 1;
    }
    .stat-divider::before,
    .stat-divider::after {
      content: "";
      flex: 1;
      height: 1px;
      background-color: rgba(255, 255, 255, 0.15);
    }
    .ratio-pill {
      display: inline-block;
      margin-top: 28px;
      padding: 10px 20px;
      border: 1.5px solid #A78BFA;
      border-radius: 999px;
      color: #A78BFA;
      font-size: 18px;
      font-weight: 700;
      position: relative;
      z-index: 1;
    }
    .ratio-caption {
      font-size: 13px;
      color: rgba(255, 255, 255, 0.7);
      margin-top: 14px;
      position: relative;
      z-index: 1;
    }
  </style>

  <section class="hero-section">
    <div>
      <span class="pill">2023 Data · States &amp; Regions</span>
      <h1 class="hero-headline">
        Alzheimer's research funding is <span class="accent">not distributed equitably</span>.
      </h1>
      <p class="hero-subhead">
        Despite similar disease burden, NIH spending per Alzheimer's death varies
        dramatically by region — reflecting where research institutions are
        located, not where the need is greatest.
      </p>
      <div class="cta-row">
        <a href="/explore" class="cta-primary">
          Explore the Data
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"></path>
          </svg>
        </a>
        <a href="/methodology" class="cta-secondary">
          Learn More
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"></path>
          </svg>
        </a>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-label">The Funding Gap</div>
      <div class="stat-value-purple">{formatCurrency(ne)}</div>
      <div class="stat-caption">per Alzheimer's death in the Northeast</div>
      <div class="stat-divider">vs.</div>
      <div class="stat-value-pink">{formatCurrency(west)}</div>
      <div class="stat-caption">per Alzheimer's death in the West</div>
      <div class="ratio-pill">{ratio} higher</div>
      <div class="ratio-caption">in the Northeast compared to the West</div>
    </div>
  </section>
</Layout>
