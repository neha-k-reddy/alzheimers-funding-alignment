    .approach-step-title {
      font-size: 14px;
      font-weight: 700;
      color: #0F1535;
      margin: 0 0 6px 0;
    }
    .approach-step-body {
      font-size: 12.5px;
      line-height: 1.5;
      color: #4B5563;
      margin: 0;
    }

    /* REGRESSION TABLE */
    .reg-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13.5px;
    }
    .reg-table thead th {
      text-align: left;
      padding: 10px 12px;
      color: #7C3AED;
      font-weight: 600;
      border-bottom: 1px solid #E5E7EB;
      font-size: 13px;
    }
    .reg-table thead th.num {
      text-align: right;
    }
    .reg-table tbody td {
      padding: 12px;
      border-bottom: 1px solid #F3F4F6;
      vertical-align: top;
    }
    .reg-table tbody td.num {
      text-align: right;
      font-variant-numeric: tabular-nums;
    }
    .reg-table tbody tr:last-child td {
      border-bottom: none;
    }
    .reg-var {
      font-weight: 600;
      color: #0F1535;
    }
    .reg-desc {
      color: #6B7280;
      font-size: 12.5px;
    }
    .reg-summary {
      background-color: #F5F3FF;
      border-radius: 8px;
      padding: 14px 18px;
      margin-top: 18px;
      display: flex;
      align-items: center;
      gap: 14px;
