---
import Layout from "../layouts/Layout.astro";
import numbers from "../../public/data/numbers.json";

const reg = numbers.regression;
const lastUpdated = numbers.metadata.last_updated;

function formatCoef(value: number): string {
  const rounded = Math.round(value * 100) / 100;
  return rounded.toLocaleString("en-US", {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  });
}

function pValueDisplay(p: number): string {
  if (p < 0.001) return "< 0.001";
  return p.toFixed(4);
}

function pValueStars(p: number): string {
  if (p < 0.001) return "***";
  if (p < 0.01) return "**";
  if (p < 0.05) return "*";
  return "";
}
---

