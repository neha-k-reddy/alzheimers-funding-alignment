      margin-right: 14px;
    }

    /* CALLOUTS */
    .callout {
      border-radius: 12px;
      padding: 18px 22px;
      display: flex;
      gap: 14px;
      align-items: start;
    }
    .callout-warn {
      background-color: #FFFBEB;
      border: 1px solid #FDE68A;
    }
    .callout-trans {
      background-color: #F5F3FF;
      border: 1px solid #DDD6FE;
    }
    .callout-icon {
      flex-shrink: 0;
      margin-top: 2px;
    }
    .callout-warn .callout-icon { color: #D97706; }
    .callout-trans .callout-icon { color: #7C3AED; }
    .callout-title {
      font-size: 14px;
      font-weight: 700;
      margin: 0 0 6px 0;
    }
    .callout-warn .callout-title { color: #92400E; }
    .callout-trans .callout-title { color: #0F1535; }
    .callout-body {
      font-size: 13.5px;
      line-height: 1.55;
      color: #4B5563;
      margin: 0;
    }

    /* DATA SOURCES SIDEBAR */
    .sources-list { display: flex; flex-direction: column; gap: 14px; }
    .source-row {
      display: flex;
      gap: 12px;
      align-items: start;
      padding-bottom: 12px;
      border-bottom: 1px solid #F3F4F6;
    }
    .source-row:last-child { border-bottom: none; padding-bottom: 0; }
    .source-icon {
      width: 36px;
      height: 36px;
      background-color: #F5F3FF;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #7C3AED;
      font-weight: 700;
      font-size: 11px;
      flex-shrink: 0;
    }
    .source-name {
      font-size: 13.5px;
      font-weight: 700;
      color: #0F1535;
      margin: 0;
    }
    .source-desc {
      font-size: 12.5px;
