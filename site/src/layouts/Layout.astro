---
interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/explore", label: "Explore the Data" },
  { href: "/methodology", label: "Methodology" },
  { href: "/how-i-built-this", label: "How I Built This" },
];

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <style is:global>
      body {
        background-color: #FAFAFA;
        font-family: Inter, system-ui, sans-serif;
        margin: 0;
        min-height: 100vh;
      }
      .header-bar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        background-color: #0F1535;
        height: 64px;
        display: flex;
        align-items: center;
      }
      .header-inner {
        max-width: 1280px;
        width: 100%;
        margin: 0 auto;
        padding: 0 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .logo-link {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
      }
      .logo-text {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
      }
      .logo-title {
        color: white;
        font-weight: 600;
        font-size: 18px;
      }
      .logo-subtitle {
        color: rgba(255, 255, 255, 0.7);
        font-size: 12px;
        font-weight: 400;
      }
      .nav-links {
        display: flex;
        align-items: center;
        gap: 32px;
      }
      .nav-link {
        color: white;
        font-size: 15px;
        text-decoration: none;
        padding-bottom: 4px;
        border-bottom: 2px solid transparent;
      }
      .nav-link.active {
        border-bottom-color: #7C3AED;
      }
      .paper-button {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border: 1px solid white;
        border-radius: 6px;
        color: white;
        font-size: 14px;
        text-decoration: none;
      }
      .paper-button:hover {
        background-color: rgba(255, 255, 255, 0.1);
      }
      main {
        padding-top: 64px;
      }
    </style>
  </head>
  <body>
    <header class="header-bar">
      <div class="header-inner">
        <a href="/" class="logo-link">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="color: white;">
            <path d="M9.5 2C7 2 5 4 5 6.5c0 .5.1 1 .2 1.4C3.9 8.6 3 10 3 11.5c0 1.3.6 2.4 1.5 3.2-.3.5-.5 1.2-.5 1.8 0 1.9 1.6 3.5 3.5 3.5.5 0 1-.1 1.4-.3.5 1 1.5 1.7 2.6 1.7 1.4 0 2.5-1 2.8-2.3.3.1.6.1.9.1 2 0 3.6-1.6 3.6-3.6 0-.7-.2-1.3-.5-1.9.9-.8 1.5-2 1.5-3.2 0-1.5-.9-2.9-2.2-3.6.1-.5.2-1 .2-1.4C17 4 15 2 12.5 2c-.9 0-1.7.3-2.4.7-.7-.4-1.5-.7-2.4-.7H9.5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"></path>
          </svg>
          <div class="logo-text">
            <span class="logo-title">Alzheimer's Funding Alignment</span>
            <span class="logo-subtitle">Data. Evidence. Equity.</span>
          </div>
        </a>

        <nav class="nav-links">
          {navLinks.map((link) => (
            <a href={link.href} class={`nav-link ${isActive(link.href) ? "active" : ""}`}>
              {link.label}
            </a>
          ))}
        </nav>

        <a href="/paper.pdf" class="paper-button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"></path>
            <path d="M14 2v6h6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"></path>
          </svg>
          View Paper (PDF)
        </a>
      </div>
    </header>

    <main>
      <slot />
    </main>
  </body>
</html>
